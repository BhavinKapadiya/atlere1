        "heading_VJVyGr": {
          "type": "heading",
          "settings": {
            "heading": "Cut and Sewn in Italy",
            "heading_size": "h1"
          }
        },
        "text_YybAYE": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Our French Work Jackets are cut and sewn in Italy, just outside Venice, in a small atelier known for its precision and discretion.</strong><br/>We chose it for its standards — not for heritage, but for execution.<br/>Each piece is carefully constructed, then refined. Metal buttons are attached by hand. Every jacket passes through strict quality control before leaving the atelier.<br/>Interlocked and reinforced seams — drawn from vintage workwear — are retained for their clean internal structure and quiet strength.<br/>What matters is the balance you feel when wearing it — considered, composed, precise.</p>"
          }
        }
      },
