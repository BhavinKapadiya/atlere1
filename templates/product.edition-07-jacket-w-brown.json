    "rich_text_AEL7Nq": {
      "type": "rich-text",
      "blocks": {
        "heading_VJVyGr": {
          "type": "heading",
          "settings": {
            "heading": "Cut and Sewn in Italy",
            "heading_size": "h1"
          }
        },
        "text_YybAYE": {
          "type": "text",
          "settings": {
            "text": "<p>Our French Work Jackets are cut and sewn in Italy, just outside Venice, in a small atelier known for its discretion and precision.<br/>It is a place where some of the most established French and Italian houses quietly produce their garments. We chose it for the level of finish — not for heritage, but for standards.<br/>Each jacket is constructed with care, then refined. The metal buttons are attached by hand. Every piece passes through meticulous quality control before it leaves the atelier. The interlocked and reinforced seams — originally developed for vintage chore jackets — are retained for their clean internal architecture and the way they give the garment quiet strength without visible excess.<br/>There is no need to overstate the process.<br/>What matters is the balance you feel when wearing it — considered, composed, and precise.</p>"
          }
        }
      },
      "block_order": [
        "heading_VJVyGr",
        "text_YybAYE"
      ],
