    "image_with_text_XUKLjz": {
      "type": "image-with-text",
      "blocks": {
        "heading_thQMBz": {
          "type": "heading",
          "settings": {
            "heading": "Materials",
            "heading_size": "h2"
          }
        },
        "text_3RzCQm": {
          "type": "text",
          "settings": {
            "text": "<p>Materials are chosen as part of the design, not as a technical requirement. We work with yarns sourced from some of the best suplplier, (<a href=\"https://www.manifatturasesia.it/\" target=\"_blank\" title=\"https://www.manifatturasesia.it/\">Sesia Manifatture</a>,<a href=\"https://lorafesta.com\" target=\"_blank\" title=\"https://lorafesta.com\"> Lora&Festa</a>, <a href=\"https://www.tollegno1900.it/it/\" target=\"_blank\" title=\"https://www.tollegno1900.it/it/\">Tollegno 1900</a>) selected for their quality, feel and consistency. Colours are developed in dialogue with current trends, while volumes are shaped to feel contemporary and forward — fashion-focused, but never forced or exaggerated. Each choice is made in relation to the silhouette and to how the piece is meant to be worn, resulting in garments that feel intentional, current and easy to live with.</p>",
            "text_style": "body"
          }
        }
