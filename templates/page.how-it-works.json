        "custom_liquid": "<style>\n  .menu-link {\n    color: #000000; /* nero */\n    text-decoration: none;\n    transition: color 0.2s ease;\n  }\n\n  .menu-link:hover {\n    color: #777777; /* grigio medio */\n    text-decoration: none;\n  }\n</style>\n\n<div class=\"page-width\" style=\"text-align: center;\">\n  <p class=\"h2\">\n    <a href=\"/pages/how-it-works\" class=\"menu-link\">How It Works</a> /\n    <a href=\"/pages/materials\" class=\"menu-link\">Materials</a> /\n    <a href=\"/pages/try-it-at-home\" class=\"menu-link\">Try it at Home</a>\n  </p>\n</div>",
