        "7eb22424-a27c-4b8d-923e-8d60c95886ef": {
          "type": "heading",
          "settings": {
            "heading": "<strong>This is a really \"Handmade in Italy\"</strong>",
            "heading_size": "h2"
          }
        },
        "3476bcf7-7725-462a-95de-85c64cd79b74": {
          "type": "text",
          "settings": {
            "text": "<p>Our Marinières are all individually handmade by our trusted knitter, Betty.<br/><br/>Her workshop, nestled in the hills surrounding the Venetian lagoon, is a small family-run business that has been handed down for generations, an example of tradition meeting innovation in Italian artisan knitwear.</p><p>We are proud to have Betty knitting our Marinières.</p><p>After she completes her work, each piece is hand embroidered, labeled and numbered in our small atelier.</p>"
          }
        }
      },
      "block_order": [
