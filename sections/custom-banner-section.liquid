      "label": "Enter First Banner Text"
    },
    {
      "type": "text",
      "id": "sub-text-1",
      "label": "Enter Sub Text"
    },
    {
      "type": "select",
      "id": "horizontal1",
      "label": "Allineamento Orizzontale",
      "options": [
        {
          "value": "0",
          "label": "Sinistra"
        },
        {
          "value": "50",
          "label": "Centro"
        },
        {
          "value": "100",
          "label": "Destra"
        }
      ],
      "default": "50"
    },
    {
      "type": "select",
      "id": "vertical1",
      "label": "Allineamento Verticale",
      "options": [
        {
          "value": "0",
          "label": "Top"
        },
        {
          "value": "50",
          "label": "Centro"
        },
        {
          "value": "100",
          "label": "Bottom"
        }
      ],
      "default": "50"
    },
    {
      "type": "url",
      "id": "first-url",
      "label": "Choose/Enter Collection Link"
    },
    {
      "type": "header",
      "content": "Second Banner Settings"
    },
    {
      "type": "image_picker",
      "id": "second-img",
      "label": "Choose Second Banner Image"
    },
    {
      "type": "text",
      "id": "second-text",
      "label": "Enter second Banner Text"
    },
    {
      "type": "text",
      "id": "sub-text-2",
      "label": "Enter Sub Text"
    },
    {
      "type": "select",
      "id": "horizontal2",
      "label": "Allineamento Orizzontale",
      "options": [
        {
          "value": "0",
          "label": "Sinistra"
        },
        {
          "value": "50",
          "label": "Centro"
        },
        {
          "value": "100",
          "label": "Destra"
        }
      ],
      "default": "50"
    },
     {
      "type": "select",
      "id": "vertical2",
      "label": "Allineamento Verticale",
      "options": [
        {
          "value": "0",
          "label": "Top"
        },
        {
          "value": "50",
          "label": "Centro"
        },
        {
          "value": "100",
          "label": "Bottom"
        }
      ],
      "default": "50"
    },
    {
      "type": "url",
      "id": "second-url",
      "label": "Choose/Enter Collection Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner Section"
    }
  ]
}
{% endschema %}