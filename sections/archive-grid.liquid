{% comment %}
  Archive Grid Section
  Dynamically displays grid items with image, title, subtitle, and link.
{% endcomment %}

<section class="archive-wrapper">
  <div class="archive-grid">

    {% for block in section.blocks %}
      <div class="archive-item">
        {% if block.settings.image %}
          <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}">
        {% endif %}

        <a href="{{ block.settings.link }}">
          <span>
            <h2>{{ block.settings.title }}</h2>
            <p>{{ block.settings.subtitle }}</p>
          </span>
        </a>
      </div>
    {% endfor %}

  </div>
</section>



<style>
.archive-grid {
  max-width:1400px;
  display:grid;
  grid-template-columns:repeat(4, 1fr);
  grid-gap:1rem;
  margin:2rem auto;
  color:white;
  display: flex;
    overflow-x: scroll;
    gap: 5px;
    margin: 5px 0;
    padding: 0;
    max-width: 100%;
}
.archive-grid div {
    flex: 0 0 calc((100vw / 3) - 5vw);
    scroll-snap-type: x mandatory;
}


.archive-item {
  position:relative;
  cursor:pointer;
}

.archive-item a {
  color:white;
  text-decoration:none;
}

.archive-item a:hover {
  text-decoration:underline;
}

.archive-item h2, .archive-item p {
  margin:0;
  line-height:1;
  color:#fff;
}

.archive-item h2 {
  font-family: "inter", sans-serif;
  text-transform: uppercase;
  font-weight: 600;
}



.archive-item h2:after {
  content:"";
  display:block;
  width:100px;
  height:1px;
  background:white;
  margin:1rem auto;
}

.archive-item span {
  position:absolute;
  top:0;
  left:0;
  width:100%;
  height:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-direction:column;
  text-align:center;
  transition: all .3s;
}

.archive-item span:hover {
  background:rgba(0,0,0,0.5);
}


@media screen and (max-width: 1200px) {
  .archive-grid {
    grid-gap:5px;
    grid-template-columns:repeat(3, 1fr);
  }
}

@media screen and (max-width: 800px) {
  .archive-grid {
    grid-gap:5px;
    grid-template-columns:repeat(2, 1fr);
  }

  .archive-item h2 {
    font-size:1rem;
  }

  .archive-item p {
    margin-bottom:0;
  }

  .archive-item h2:after {
    margin:0.5rem auto;
  }
  .archive-grid div {
        flex: 0 0 calc((100vw / 2) - 7vw);
    }
}
</style>



{% schema %}
{
  "name": "Archive Grid",
  "settings": [],
  "blocks": [
    {
      "type": "archive_item",
      "name": "Archive Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Item Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "BATCH NO.22"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [
    {
      "name": "Archive Grid",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
